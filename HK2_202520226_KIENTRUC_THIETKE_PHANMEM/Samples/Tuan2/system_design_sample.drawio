        <mxCell id="line_stripe_webhook" edge="1" parent="1" source="stripe_gateway" style="entryX=0.006;entryY=0.567;entryDx=0;entryDy=0;entryPerimeter=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;strokeColor=#635BFF;strokeWidth=2;" target="apigw" value="Webhook Callback">
