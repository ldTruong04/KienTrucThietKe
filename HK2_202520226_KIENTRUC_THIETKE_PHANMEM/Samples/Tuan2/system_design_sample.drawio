        </mxCell>
        <mxCell id="4zruMlHUtB4qcEl_Etqq-2" parent="1" style="text;html=1;strokeColor=#82b366;fillColor=#d5e8d4;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=1;padding=10;fontSize=11;" value="&lt;b&gt;QUY TRÌNH CHECK AUTH (XÁC THỰC):&lt;/b&gt;&lt;br&gt;1. User gửi request kèm &lt;b&gt;JWT Token&lt;/b&gt; trong Header.&lt;br&gt;2. API Gateway chặn lại, gọi API &lt;i&gt;GET /validate&lt;/i&gt; sang &lt;b&gt;Auth Service&lt;/b&gt;.&lt;br&gt;3. Auth Service kiểm tra Token trong &lt;b&gt;Redis&lt;/b&gt; (còn hạn không? đã logout chưa?).&lt;br&gt;4. Nếu OK, Gateway đính thêm&amp;nbsp;&lt;span style=&quot;font-size: 8pt; color: light-dark(rgb(0, 0, 0), rgb(237, 237, 237)); background-color: transparent;&quot;&gt;&amp;nbsp;X-User-ID, X-User-Role&lt;/span&gt;&amp;nbsp;vào Header và cho phép đi tiếp vào EKS." vertex="1">
          <mxGeometry height="80" width="520" x="40" y="680" as="geometry" />
        </mxCell>
        <mxCell id="jrxKDeu34Ku4zPwbpvSs-1" parent="1" style="shape=actor;whiteSpace=wrap;html=1;" value="" vertex="1">
          <mxGeometry height="36" width="30" x="325" y="4" as="geometry" />
        </mxCell>
        <mxCell id="jrxKDeu34Ku4zPwbpvSs-3" edge="1" parent="1" source="jrxKDeu34Ku4zPwbpvSs-1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="340" y="120" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="jrxKDeu34Ku4zPwbpvSs-4" connectable="0" parent="jrxKDeu34Ku4zPwbpvSs-3" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];" value="DNS Query" vertex="1">
          <mxGeometry relative="1" x="-0.2042" as="geometry">
            <mxPoint as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="jrxKDeu34Ku4zPwbpvSs-5" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;autosize=1;resizable=0;" value="Client" vertex="1">
          <mxGeometry height="30" width="50" x="275" y="20" as="geometry" />
        </mxCell>
        <mxCell id="NaVJF0oHeJBTjOtBW-QP-1" parent="1" style="text;html=1;strokeColor=#82b366;fillColor=#d5e8d4;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=1;padding=10;fontSize=11;spacing=2;spacingBottom=8;spacingLeft=6;" value="&lt;p align=&quot;left&quot; style=&quot;line-height: 1.15px; margin-bottom: 0.15cm; background: transparent; font-size: medium; font-variant-numeric: normal; font-variant-east-asian: normal; font-variant-alternates: normal; font-variant-position: normal; font-variant-emoji: normal;&quot;&gt;&lt;font color=&quot;#000000&quot;&gt;&lt;font face=&quot;Helvetica&quot;&gt;&lt;font style=&quot;font-size: 8pt;&quot;&gt;&lt;b&gt;QUY TRÌNH CHECK AUTH (XÁC THỰC – KHÔNG QUA AUTH SERVICE):&lt;/b&gt;&lt;/font&gt;&lt;/font&gt;&lt;/font&gt;&lt;/p&gt;&lt;p align=&quot;left&quot; style=&quot;line-height: 1.15px; margin-bottom: 0.15cm; background: transparent; font-size: medium; font-variant-numeric: normal; font-variant-east-asian: normal; font-variant-alternates: normal; font-variant-position: normal; font-variant-emoji: normal;&quot;&gt;&lt;font color=&quot;#000000&quot;&gt;&lt;font face=&quot;Helvetica&quot;&gt;&lt;font style=&quot;font-size: 8pt;&quot;&gt;1. User gửi request kèm &lt;b&gt;JWT Token&lt;/b&gt; trong &lt;b&gt;Header&lt;/b&gt;.&lt;/font&gt;&lt;/font&gt;&lt;/font&gt;&lt;/p&gt;&lt;p align=&quot;left&quot; style=&quot;line-height: 1.15px; margin-bottom: 0.15cm; background: transparent; font-size: medium; font-variant-numeric: normal; font-variant-east-asian: normal; font-variant-alternates: normal; font-variant-position: normal; font-variant-emoji: normal;&quot;&gt;&lt;font color=&quot;#000000&quot;&gt;&lt;font face=&quot;Helvetica&quot;&gt;&lt;font style=&quot;font-size: 8pt;&quot;&gt;2. API Gateway chặn request và trích xuất token từ header Authorization: Bearer &amp;lt;JWT&amp;gt;.&lt;/font&gt;&lt;/font&gt;&lt;/font&gt;&lt;/p&gt;&lt;p align=&quot;left&quot; style=&quot;line-height: 1.15px; margin-bottom: 0.15cm; background: transparent; font-size: medium; font-variant-numeric: normal; font-variant-east-asian: normal; font-variant-alternates: normal; font-variant-position: normal; font-variant-emoji: normal;&quot;&gt;&lt;font color=&quot;#000000&quot;&gt;&lt;font face=&quot;Helvetica&quot;&gt;&lt;font style=&quot;font-size: 8pt;&quot;&gt;&lt;span style=&quot;background: transparent;&quot;&gt;3. &lt;/span&gt;Gateway tự verify JWT signature bằng Public Key / Secret Key để đảm bảo token được ký bởi hệ thống.&lt;/font&gt;&lt;/font&gt;&lt;/font&gt;&lt;/p&gt;&lt;p align=&quot;left&quot; style=&quot;line-height: 1.15px; margin-bottom: 0.15cm; background: transparent; font-size: medium; font-variant-numeric: normal; font-variant-east-asian: normal; font-variant-alternates: normal; font-variant-position: normal; font-variant-emoji: normal;&quot;&gt;&lt;font color=&quot;#000000&quot;&gt;&lt;font face=&quot;Helvetica&quot;&gt;&lt;font style=&quot;font-size: 8pt;&quot;&gt;4. Gateway kiểm tra exp (expiration) trong payload để xác nhận token còn hiệu lực.&lt;/font&gt;&lt;/font&gt;&lt;/font&gt;&lt;/p&gt;&lt;p align=&quot;left&quot; style=&quot;line-height: 1.15px; margin-bottom: 0.15cm; background: transparent; font-size: medium; font-variant-numeric: normal; font-variant-east-asian: normal; font-variant-alternates: normal; font-variant-position: normal; font-variant-emoji: normal;&quot;&gt;&lt;font color=&quot;#000000&quot;&gt;&lt;font face=&quot;Helvetica&quot;&gt;&lt;font style=&quot;font-size: 8pt;&quot;&gt;5. Nếu token hợp lệ, Gateway trích xuất thông tin người dùng (ví dụ: user_id, role).&lt;/font&gt;&lt;/font&gt;&lt;/font&gt;&lt;/p&gt;&lt;p align=&quot;left&quot; style=&quot;line-height: 1.15px; margin-bottom: 0.15cm; background: transparent; font-size: medium; font-variant-numeric: normal; font-variant-east-asian: normal; font-variant-alternates: normal; font-variant-position: normal; font-variant-emoji: normal;&quot;&gt;&lt;font color=&quot;#000000&quot;&gt;&lt;font face=&quot;Helvetica&quot;&gt;&lt;font style=&quot;font-size: 8pt;&quot;&gt;6. Gateway đính thêm thông tin vào header request (ví dụ: X-User-ID, X-User-Role).&lt;/font&gt;&lt;/font&gt;&lt;/font&gt;&lt;/p&gt;&lt;p align=&quot;left&quot; style=&quot;line-height: 1.15px; margin-bottom: 0.15cm; background: transparent; font-size: medium; font-variant-numeric: normal; font-variant-east-asian: normal; font-variant-alternates: normal; font-variant-position: normal; font-variant-emoji: normal;&quot;&gt;&lt;font color=&quot;#000000&quot;&gt;&lt;font face=&quot;Helvetica&quot;&gt;&lt;font style=&quot;font-size: 8pt;&quot;&gt;7. Gateway forward request đến ALB → EKS Cluster để các service xử lý.&lt;/font&gt;&lt;/font&gt;&lt;/font&gt;&lt;/p&gt;&lt;p align=&quot;left&quot; style=&quot;line-height: 1.15px; margin-bottom: 0.15cm; background: transparent; font-size: medium; font-variant-numeric: normal; font-variant-east-asian: normal; font-variant-alternates: normal; font-variant-position: normal; font-variant-emoji: normal;&quot;&gt;&lt;font color=&quot;#000000&quot;&gt;&lt;font face=&quot;Helvetica&quot;&gt;&lt;font style=&quot;font-size: 8pt;&quot;&gt;8. Nếu token không hợp lệ hoặc hết hạn → Gateway trả về 401 Unauthorized.&lt;/font&gt;&lt;/font&gt;&lt;/font&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="190" width="520" x="40" y="880" as="geometry" />
        </mxCell>
        <mxCell id="wGo9E-O1Luv6ZqZxfxSb-1" parent="1" style="text;html=1;strokeColor=#d80027;fillColor=#f8cecc;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=1;padding=10;fontSize=11;spacingLeft=6;spacingRight=3;" value="&lt;b&gt;AMAZON EKS (KUBERNETES):&lt;/b&gt;&lt;br&gt;1. &lt;b&gt;Control Plane:&lt;/b&gt; AWS quản lý API Server, Scheduler để điều phối hệ thống.&lt;br&gt;2. &lt;b&gt;Worker Nodes:&lt;/b&gt; Các máy chủ ảo (EC2) chạy các Service dạng &lt;b&gt;Pods&lt;/b&gt;.&lt;br&gt;3. &lt;b&gt;Auto-Scaling:&lt;/b&gt; Tự động tăng số lượng Pod khi CPU cao và tự phục hồi (Self-healing) khi Service bị lỗi." vertex="1">
          <mxGeometry height="110" width="310" x="2230" y="90" as="geometry" />
        </mxCell>
        <mxCell id="CggfvcGbD-rbv6qczdP1-1" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fontColor=#000000;darkOpacity=0.05;fillColor=#FFF9B2;strokeColor=none;fillStyle=solid;direction=west;gradientDirection=north;gradientColor=#FFF2A1;shadow=1;size=20;pointerEvents=1;verticalAlign=top;" value="&lt;b style=&quot;text-align: left;&quot;&gt;CI/CD Flow:&amp;nbsp;&lt;/b&gt;&lt;span style=&quot;text-align: left;&quot;&gt;mọi thay đổi source code đều được tự động Build thành Docker Image và Deploy lên EKS Cluster&lt;/span&gt;" vertex="1">
          <mxGeometry height="40" width="320" x="150" y="480" as="geometry" />
        </mxCell>
        <mxCell id="CggfvcGbD-rbv6qczdP1-2" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fontColor=#000000;darkOpacity=0.05;fillColor=#FFF9B2;strokeColor=none;fillStyle=solid;direction=west;gradientDirection=north;gradientColor=#FFF2A1;shadow=1;size=20;pointerEvents=1;verticalAlign=top;align=left;spacingLeft=6;" value="&lt;b style=&quot;font-size: 11px;&quot;&gt;Route53 (DNS Service):&lt;/b&gt;&lt;div&gt;&lt;span style=&quot;font-size: 11px;&quot;&gt;- Đóng vai trò phân giải tên miền (ví dụ: myapp.com) thành địa chỉ IP của hệ thống.&amp;nbsp;&lt;/span&gt;&lt;div style=&quot;font-size: 11px;&quot;&gt;- Health Check để điều hướng user đến server đang hoạt động tốt nhất.&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;Rate Limiter:&lt;/b&gt;&amp;nbsp;cấu hình ở server&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="120" width="320" x="680" y="15.809999999999988" as="geometry" />
        </mxCell>
        <mxCell id="CggfvcGbD-rbv6qczdP1-3" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fontColor=#000000;darkOpacity=0.05;fillColor=#FFF9B2;strokeColor=none;fillStyle=solid;direction=west;gradientDirection=north;gradientColor=#FFF2A1;shadow=1;size=20;pointerEvents=1;" value="&lt;p align=&quot;left&quot; style=&quot;line-height: 1px; margin-bottom: 0.15cm; background: transparent;&quot;&gt;&lt;b&gt;Auth Service:&lt;/b&gt;&lt;/p&gt;&lt;p align=&quot;left&quot; style=&quot;line-height: 1px; margin-bottom: 0.15cm; background: transparent;&quot;&gt;1. verify signature&lt;/p&gt;&lt;p align=&quot;left&quot; style=&quot;line-height: 1px; margin-bottom: 0.15cm; background: transparent;&quot;&gt;2. check expiration&lt;/p&gt;&lt;p align=&quot;left&quot; style=&quot;line-height: 1px; margin-bottom: 0.15cm; background: transparent;&quot;&gt;3. check Redis blacklist&lt;/p&gt;&lt;p align=&quot;left&quot; style=&quot;line-height: 1px; margin-bottom: 0.15cm; background: transparent;&quot;&gt;4. check logout&lt;/p&gt;&lt;p align=&quot;left&quot; style=&quot;line-height: 1px; margin-bottom: 0.15cm; background: transparent;&quot;&gt;&lt;br style=&quot;font-size: 11px;&quot;&gt;&lt;/p&gt;&lt;p align=&quot;left&quot; style=&quot;font-size: 11px; background: transparent; line-height: 1px; margin-bottom: 0.15cm;&quot;&gt;&lt;b&gt;Ưu điểm:&lt;/b&gt;&lt;/p&gt;&lt;p align=&quot;left&quot; style=&quot;font-size: 11px; background: transparent; line-height: 1px; margin-bottom: 0.15cm;&quot;&gt;1. Có thể revoke token ngay lập tức (check ở Redis).&amp;nbsp;&lt;/p&gt;&lt;p align=&quot;left&quot; style=&quot;font-size: 11px; background: transparent; line-height: 1px; margin-bottom: 0.15cm;&quot;&gt;&amp;nbsp; &amp;nbsp; Nếu logout thì request sau sẽ bị&amp;nbsp;&lt;b&gt;reject&lt;/b&gt;&amp;nbsp;ngay&lt;/p&gt;&lt;p align=&quot;left&quot; style=&quot;font-size: 11px; background: transparent; line-height: 1px; margin-bottom: 0.15cm;&quot;&gt;2.&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Dễ maintain hơn do code tập trung&lt;/span&gt;&lt;/p&gt;&lt;p align=&quot;left&quot; style=&quot;font-size: 11px; background: transparent; line-height: 1px; margin-bottom: 0.15cm;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;3.&amp;nbsp;&lt;/span&gt;&lt;span data-start=&quot;522&quot; data-end=&quot;553&quot; style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Dễ mở rộng các rule&lt;/span&gt;&lt;/p&gt;&lt;p align=&quot;left&quot; style=&quot;line-height: 1px; margin-bottom: 0.15cm; background: transparent;&quot;&gt;&lt;span style=&quot;font-size: 11px;&quot;&gt;&amp;nbsp; &amp;nbsp; Có thể kiểm tra thêm: device login, IP, block user,...&lt;/span&gt;&lt;/p&gt;&lt;p align=&quot;left&quot; style=&quot;font-size: 11px; background: transparent; line-height: 1px; margin-bottom: 0.15cm;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/p&gt;&lt;p align=&quot;left&quot; style=&quot;font-size: 11px; background: transparent; line-height: 1px; margin-bottom: 0.15cm;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;b&gt;Nhược điểm:&lt;/b&gt;&lt;/span&gt;&lt;/p&gt;&lt;p align=&quot;left&quot; style=&quot;font-size: 11px; background: transparent; line-height: 1px; margin-bottom: 0.15cm;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;1. Tăng latency&lt;/span&gt;&lt;/p&gt;&lt;p align=&quot;left&quot; style=&quot;font-size: 11px; background: transparent; line-height: 1px; margin-bottom: 0.15cm;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;2.&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Auth Service thành bottleneck&lt;/span&gt;&lt;/p&gt;&lt;p align=&quot;left&quot; style=&quot;font-size: 11px; background: transparent; line-height: 1px; margin-bottom: 0.15cm;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp; &amp;nbsp;&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Nếu traffic lớn, Auth Service phải xử lý rất nhiều request validate.&lt;/span&gt;&lt;/p&gt;&lt;p align=&quot;left&quot; style=&quot;font-size: 11px; background: transparent; line-height: 1px; margin-bottom: 0.15cm;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;3.&amp;nbsp;&lt;/span&gt;&lt;span data-start=&quot;868&quot; data-end=&quot;895&quot; style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Single point of failure&lt;/span&gt;&lt;/p&gt;&lt;p align=&quot;left&quot; style=&quot;line-height: 1px; margin-bottom: 0.15cm; background: transparent;&quot;&gt;&lt;span style=&quot;font-size: 11px;&quot;&gt;&amp;nbsp; &amp;nbsp; Nếu Auth Service down thì toàn bộ request API có thể bị fail.&lt;/span&gt;&lt;/p&gt;&lt;div style=&quot;font-size: 11px; text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;4.&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Tăng network traffic: 1 request của user + 1 request validate&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="270" width="391" x="540" y="610" as="geometry" />
        </mxCell>
        <mxCell id="CggfvcGbD-rbv6qczdP1-4" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fontColor=#000000;darkOpacity=0.05;fillColor=#FFF9B2;strokeColor=none;fillStyle=solid;direction=west;gradientDirection=north;gradientColor=#FFF2A1;shadow=1;size=20;pointerEvents=1;" value="&lt;p align=&quot;left&quot; style=&quot;font-size: 11px; background: transparent; line-height: 1px; margin-bottom: 0.2cm;&quot;&gt;&lt;b&gt;Ưu điểm:&lt;/b&gt;&lt;/p&gt;&lt;p align=&quot;left&quot; style=&quot;font-size: 11px; background: transparent; line-height: 1px; margin-bottom: 0.2cm;&quot;&gt;1. Giảm latency đáng kể&lt;/p&gt;&lt;p align=&quot;left&quot; style=&quot;font-size: 11px; background: transparent; line-height: 1px; margin-bottom: 0.2cm;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp;Không cần gọi API /validate → Gateway verify JWT trực tiếp → response nhanh hơn.&lt;/p&gt;&lt;p align=&quot;left&quot; style=&quot;font-size: 11px; background: transparent; line-height: 1px; margin-bottom: 0.2cm;&quot;&gt;2. Không tạo bottleneck ở Auth Service&lt;/p&gt;&lt;p align=&quot;left&quot; style=&quot;font-size: 11px; background: transparent; line-height: 1px; margin-bottom: 0.2cm;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp;Auth Service không phải xử lý hàng nghìn request validate mỗi giây.&lt;/p&gt;&lt;p align=&quot;left&quot; style=&quot;font-size: 11px; background: transparent; line-height: 1px; margin-bottom: 0.2cm;&quot;&gt;3. Giảm network traffic&lt;/p&gt;&lt;p align=&quot;left&quot; style=&quot;font-size: 11px; background: transparent; line-height: 1px; margin-bottom: 0.2cm;&quot;&gt;&amp;nbsp; &amp;nbsp; Chỉ có 1 request từ client → gateway, không phát sinh thêm request validate nội bộ.&lt;/p&gt;&lt;p align=&quot;left&quot; style=&quot;font-size: 11px; background: transparent; line-height: 1px; margin-bottom: 0.2cm;&quot;&gt;4. Scalable tốt hơn&lt;/p&gt;&lt;p align=&quot;left&quot; style=&quot;font-size: 11px; background: transparent; line-height: 1px; margin-bottom: 0.2cm;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp;Vì JWT là stateless, Gateway chỉ cần public key/secret để verify → dễ scale ngang&lt;/p&gt;&lt;p align=&quot;left&quot; style=&quot;font-size: 11px; background: transparent; line-height: 1px; margin-bottom: 0.2cm;&quot;&gt;5. Hệ thống vẫn hoạt động nếu Auth Service down&lt;/p&gt;&lt;p align=&quot;left&quot; style=&quot;font-size: 11px; background: transparent; line-height: 1px; margin-bottom: 0.2cm;&quot;&gt;&amp;nbsp; &amp;nbsp; Các API khác vẫn chạy bình thường miễn là JWT còn hạn.&lt;/p&gt;&lt;p align=&quot;left&quot; style=&quot;font-size: 11px; background: transparent; line-height: 1px; margin-bottom: 0.2cm;&quot;&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/p&gt;&lt;p align=&quot;left&quot; style=&quot;font-size: 11px; background: transparent; line-height: 1px; margin-bottom: 0.2cm;&quot;&gt;&lt;b&gt;Nhược điểm:&lt;/b&gt;&lt;/p&gt;&lt;p align=&quot;left&quot; style=&quot;font-size: 11px; background: transparent; line-height: 1px; margin-bottom: 0.2cm;&quot;&gt;1. Không revoke token ngay lập tức&lt;/p&gt;&lt;p align=&quot;left&quot; style=&quot;font-size: 11px; background: transparent; line-height: 1px; margin-bottom: 0.2cm;&quot;&gt;&amp;nbsp; &amp;nbsp; Nếu user logout hoặc token bị lộ thì JWT vẫn hợp lệ cho tới khi exp hết hạn.&lt;/p&gt;&lt;p align=&quot;left&quot; style=&quot;font-size: 11px; background: transparent; line-height: 1px; margin-bottom: 0.2cm;&quot;&gt;2. Không kiểm tra được trạng thái session&lt;/p&gt;&lt;p align=&quot;left&quot; style=&quot;font-size: 11px; background: transparent; line-height: 1px; margin-bottom: 0.2cm;&quot;&gt;&amp;nbsp; &amp;nbsp; Gateway chỉ kiểm tra signature và exp, không biết user đã logout hay bị block hay chưa.&lt;/p&gt;&lt;p align=&quot;left&quot; style=&quot;font-size: 11px; background: transparent; line-height: 1px; margin-bottom: 0.2cm;&quot;&gt;3. Khó áp dụng các rule auth phức tạp&lt;/p&gt;&lt;p align=&quot;left&quot; style=&quot;font-size: 11px; background: transparent; line-height: 1px; margin-bottom: 0.2cm;&quot;&gt;&amp;nbsp; &amp;nbsp; Ví dụ: giới hạn số thiết bị login, block theo IP … vì Gateway không query Redis/ DB.&lt;/p&gt;&lt;p align=&quot;left&quot; style=&quot;font-size: 11px; background: transparent; line-height: 1px; margin-bottom: 0.2cm;&quot;&gt;4. Cần quản lý key ký JWT cẩn thận&lt;/p&gt;" vertex="1">
          <mxGeometry height="270" width="490" x="460" y="970" as="geometry" />
        </mxCell>
        <mxCell id="9Ks9FYwOGJzeDRIUs4cS-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontStyle=1;fontSize=15;" value="Fig 4. System Design" vertex="1">
          <mxGeometry height="30" width="400" x="1199" y="1137" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
