# Redis Connection
REDIS_URL=redis://localhost:6379
# Note for LAN deploy: Change localhost to the IP of the machine running Redis (e.g. 192.168.1.10)

# Service Ports
PRODUCT_SERVICE_PORT=8081
CART_SERVICE_PORT=8082
ORDER_SERVICE_PORT=8083
INVENTORY_SERVICE_PORT=8084

# Service URLs for internal communication
# Change localhost to IP addresses for LAN deployment
PRODUCT_SERVICE_URL=http://localhost:8081
CART_SERVICE_URL=http://localhost:8082
ORDER_SERVICE_URL=http://localhost:8083
INVENTORY_SERVICE_URL=http://localhost:8084
